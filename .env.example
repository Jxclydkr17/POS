# ============================================================
# Violette POS — Configuración
# ============================================================
# Copie este archivo como .env y ajuste los valores.
# La aplicación lo crea automáticamente en la primera ejecución.
# ============================================================

# --- General ---
APP_NAME=ViolettePOS
APP_ENV=production
APP_DEBUG=False

# --- Base de datos ---
# DB_ENGINE: "sqlite" (standalone, sin instalar nada) o "mysql" (servidor externo)
DB_ENGINE=sqlite

# SQLite (solo si DB_ENGINE=sqlite)
DB_SQLITE_PATH=violette_pos.db

# MySQL (solo si DB_ENGINE=mysql)
 DB_USER=root
 DB_PASSWORD=tu_password
 DB_HOST=localhost
 DB_PORT=3306
 DB_NAME=violette_db

# --- Seguridad ---
# Se genera automáticamente si está vacío
SECRET_KEY=

# --- Hacienda (Facturación Electrónica) ---
# Ambiente: sandbox (pruebas) o production (producción)
HACIENDA_ENV=sandbox
HACIENDA_API=https://api.comprobanteselectronicos.go.cr

# Certificado de firma digital (.p12)
# Coloque el archivo en la carpeta certs/ y ponga la ruta aquí
HACIENDA_CERT_PATH=
HACIENDA_CERT_PASS=

# Credenciales OAuth2 de Hacienda (para envío)
HACIENDA_USER=
HACIENDA_PASSWORD=

# --- Correo electrónico (para envío de comprobantes) ---
EMAIL_USER=
EMAIL_PASS=

# ---API_KEY (opcional, para asistente AI) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
