# ============================================================
# Violette POS — .gitignore
# FASE D — Fix D.3: Actualizado con rutas correctas
# ============================================================

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg

# ── Entorno virtual ──
.venv/
venv/
env/
ENV/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Variables de entorno (secretos) ──
.env
.env.local
.env.production

# ── Base de datos ──
violette_pos.db
violette_pos.db-wal
violette_pos.db-shm
*.db-journal

# ── Datos de runtime (se generan automáticamente) ──
data/logs/
data/pdfs/
data/backups/
data/backup_status.json
data/.secret_key_fingerprint
data/login_attempts.json

# ── Sesión de usuario ──
session.json

# ── Certificados y credenciales ──
data/certs/
*.p12
*.pfx
*.pem
*.key

# ── PyInstaller / distribución ──
dist/
build/
*.exe
*.msi
Output/

# ── Directorios legacy (ya migrados a data/) ──
app/pdfs/
app/backups/

# ── Uploads de usuario ──
app/uploads/logos/*
!app/uploads/logos/.gitkeep

# ── Mantener estructura de carpetas vacías ──
!data/pdfs/.gitkeep
!data/backups/.gitkeep
!data/logs/.gitkeep

# Artefactos legacy en la raíz (no usar, el código escribe en data/)
/logs/
/generated_pdfs/
/exports/
/chart_bar.png
/chart_pie.png